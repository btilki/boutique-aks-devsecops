      "targets": [{ "expr": "count(kube_node_info)", "legendFormat": "nodes" }],
      "title": "Node Count",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
